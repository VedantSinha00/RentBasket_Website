# RentBasket API proxy — server-side secrets (NEVER VITE_-prefixed, never in the client).
# Copy to .env for local dev, or set as environment variables in the Netlify site.

# Privileged app key used to mint the JWT (/get-jwt-token).
API_APP_KEY=base64:...

# Read-only catalog key for /get-amenity-types (Authorization-Key header).
CATALOG_API_KEY=...

# Upstream API origins.
UPSTREAM_API=https://testapi.rentbasket.com
UPSTREAM_AWS=https://testaws.rentbasket.com

# Browser origin(s) allowed to call the proxy (comma-separated).
# Production: https://home.rentbasket.com   Local dev: http://localhost:8080
ALLOWED_ORIGIN=https://home.rentbasket.com,http://localhost:8080
