# RentBasket Website — environment variables
# Copy this to .env.local for local development.
# This SPA has no backend; most variables are Vite build-time values.

# Base URL path — used by Vite and React Router.
# For GitHub Pages: /RentBasket_Website  |  For local: /
VITE_BASE_URL=/

# App name (used in meta tags and OG)
VITE_APP_NAME=RentBasket

# Backend API base URL. LEAVE EMPTY to use the bundled mock catalog.
# VITE_API_BASE_URL=https://testapi.rentbasket.com

# App key for the /get-jwt-token auth endpoint.
# VITE_API_APP_KEY=base64:...

# Static key for the bulk catalog endpoint (GET /get-amenity-types).
# Uses Authorization-Key header, not Bearer JWT. Get from Shivam.
# VITE_CATALOG_API_KEY=

# Optional: Analytics / tracking (leave empty to disable)
# VITE_GA_ID=G-XXXXXXXXXX

# Optional: WhatsApp contact number for FloatingCallButton
VITE_WHATSAPP_NUMBER=919999999999

# Optional: Formspree or other form endpoint for contact/lead forms
# VITE_FORM_ENDPOINT=https://formspree.io/f/your-id
